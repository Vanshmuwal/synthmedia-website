# ──────────────────────────────────────────────────────────────────────────────
# Instagram Trend Tracker — Environment Variables
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────────────────────────────────────

# ─── META ADS LIBRARY (Free) ──────────────────────────────────────────────────
# Get from: developers.facebook.com → Your App → Marketing API → Access Token
# Required permission: ads_read
META_ACCESS_TOKEN=your_meta_access_token_here

# ─── INSTAGRAM GRAPH API (For Reels URLs) ────────────────────────────────────
# Get from: developers.facebook.com → Your App → Instagram Graph API
# Required permissions: instagram_basic, instagram_manage_insights, pages_read_engagement
# Token type: Long-lived User Access Token (valid 60 days — refresh with token refresh endpoint)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# Your Instagram Business or Creator Account ID (numeric, e.g. 17841400000000000)
# Find it at: graph.facebook.com/me/accounts?access_token=YOUR_TOKEN
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ─── SOCIAL BLADE API (Optional — paid) ──────────────────────────────────────
# Only needed for the official API. App works without this via public scraping.
# Get from: socialblade.com/business/api
SOCIAL_BLADE_API_KEY=

# ─── APP SETTINGS (Optional) ─────────────────────────────────────────────────
# Default country for Google Trends (ISO 2-letter code)
DEFAULT_COUNTRY=US
